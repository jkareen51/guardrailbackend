# Server
HOST=0.0.0.0
PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/guardrailbackend
DB_MAX_CONNECTIONS=20
DB_ACQUIRE_TIMEOUT_MS=10000

# Google auth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs

# Session auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_TTL_HOURS=24
ADMIN_WALLET_ADDRESSES=0x6D21167d874C842386e8c484519B5ddBBaB87b43
OPERATOR_PRIVATE_KEY=replace_with_admin_private_key

# Account abstraction / smart accounts
# These env names stay as monad_* because the copied auth/account-abstraction code expects them.
MONAD_RPC_URL=https://rpc.sepolia-api.lisk.com
MONAD_RPC_URLS=https://rpc.sepolia-api.lisk.com,https://lisk-sepolia.drpc.org
MONAD_CHAIN_ID=4202
AA_BUNDLER_RPC_URL=replace_with_lisk_bundler_rpc_url
AA_ENTRY_POINT_ADDRESS=0x0000000000000000000000000000000000000000
AA_SIMPLE_ACCOUNT_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
AA_USER_OPERATION_POLL_INTERVAL_MS=1500
AA_USER_OPERATION_TIMEOUT_MS=120000
AA_OWNER_ENCRYPTION_KEY=replace_with_64_hex_chars
AA_OWNER_ENCRYPTION_KEY_VERSION=1

# Current deployed Guardrail addresses you gave me.
# These are not consumed by the copied auth slice yet, but kept here for reference.
ACCESS_CONTROL_ADDRESS=0x0D9c1384a207C2b8c8Ef9A5B9CCCF5ECa7A82737
